{
    "name": "shopvote/shopvote-reviews",
    "description": "PrestaShop 8.2.x module for ShopVote VotesAPI integration",
    "version": "1.3.0",
    "type": "prestashop-module",
    "license": "MIT",
    "authors": [
        {
            "name": "ShopVote Integration",
            "email": "support@example.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-simplexml": "*",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ShopVote\\ShopVoteReviews\\": "src/"
        },
        "classmap": [
            "shopvotereviews.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ShopVote\\ShopVoteReviews\\Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
