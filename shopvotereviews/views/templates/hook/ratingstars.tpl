{** ShopVote RatingStars / floating badge configuration for the module-owned loader. *}
<meta id="shopvote-ratingstars-config"
      data-shopvote-script-url="{$shopvote_ratingstars_script_url|escape:'htmlall':'UTF-8'}"
      data-shopvote-shop-id="{$shopvote_ratingstars_shop_id|intval}"
      data-shopvote-badge-type="{$shopvote_ratingstars_badge_type|intval}"
      data-shopvote-language="{$shopvote_ratingstars_language|escape:'htmlall':'UTF-8'}"
      data-shopvote-z-index="{$shopvote_ratingstars_z_index|escape:'htmlall':'UTF-8'}"
      data-shopvote-function="{$shopvote_ratingstars_function|escape:'htmlall':'UTF-8'}"
      data-shopvote-arguments="{$shopvote_ratingstars_arguments|escape:'htmlall':'UTF-8'}">
